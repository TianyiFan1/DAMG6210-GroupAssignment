# CoHabitant Docker build exclusions
.git
.github
.hypothesis
.pytest_cache
__pycache__
*.pyc
*.pyo
venv/
.venv/
env/
.env
.env.local
tests/
*.md
*.svg
*.pbix
*.pdf
# .streamlit/secrets.toml — NOT excluded; picked up by COPY . .
# It's gitignored so it won't be in CI builds (which is fine —
# CI only checks the health endpoint, not DB connectivity).
# For local Azure builds: copy secrets.azure.toml → secrets.toml first.
.DS_Store
Thumbs.db
